<style>
  :root {
    --bg: #ffffff;
    --bg2: #f8f7f5;
    --border: #e8e5e0;
    --text: #1a1a1a;
    --muted: #9a9590;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; font-weight: 300; }

/* TOPBAR */
.topbar {
background: var(–bg2);
border-bottom: 1px solid var(–border);
display: flex; align-items: center; justify-content: center;
gap: 32px; height: 34px;
}
.topbar a {
font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase;
color: var(–muted); text-decoration: none; transition: color 0.15s;
}
.topbar a:hover { color: var(–text); }

/* HEADER */
header {
position: sticky; top: 0; z-index: 50;
background: rgba(255,255,255,0.97);
backdrop-filter: blur(12px);
border-bottom: 1px solid var(–border);
}
.header-inner {
display: flex; align-items: center; justify-content: space-between;
padding: 0 32px; height: 54px;
}
.logo {
font-family: ‘Cormorant Garamond’, serif;
font-size: 1.35rem; font-weight: 600;
letter-spacing: 0.14em; text-transform: uppercase; color: var(–text);
flex-shrink: 0;
}

/* TABS */
.tabs {
display: flex;
gap: 4px;
background: var(–bg2);
border-radius: 6px;
padding: 4px;
}
.tab {
padding: 6px 20px;
border: none; background: transparent;
font-family: ‘Inter’, sans-serif;
font-size: 0.7rem; font-weight: 500;
letter-spacing: 0.1em; text-transform: uppercase;
color: var(–muted); cursor: pointer;
border-radius: 4px;
transition: all 0.18s;
}
.tab.active { background: var(–text); color: #fff; }
.tab:hover:not(.active) { color: var(–text); }

/* GRID */
.grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 1px;
background: var(–border);
border-top: 1px solid var(–border);
}

/* CARD */
.card { background: var(–bg); display: flex; flex-direction: column; transition: background 0.18s; }
.card:hover { background: var(–bg2); }

.card-visual {
width: 100%; aspect-ratio: 1;
background: var(–bg2);
display: flex; align-items: center; justify-content: center;
font-size: 3.5rem;
}
.card-body { padding: 14px 18px 18px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
.card-tag { font-size: 0.58rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(–muted); }
.card-name { font-family: ‘Inter’, sans-serif; font-size: 0.88rem; font-weight: 500; line-height: 1.35; }
.card-note { font-size: 0.72rem; color: var(–muted); line-height: 1.6; }
.card-footer {
margin-top: auto; padding-top: 12px;
border-top: 1px solid var(–border);
display: flex; align-items: center; justify-content: space-between; gap: 8px;
}
.card-price { font-family: ‘Cormorant Garamond’, serif; font-size: 1.15rem; font-weight: 600; }
.card-price-from { font-size: 0.55rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(–muted); display: block; margin-bottom: 1px; }

.btn-comprar {
display: inline-block;
background: var(–text); color: #fff;
font-family: ‘Inter’, sans-serif;
font-size: 0.65rem; font-weight: 500;
letter-spacing: 0.1em; text-transform: uppercase;
text-decoration: none;
padding: 8px 16px; border-radius: 4px;
white-space: nowrap;
transition: opacity 0.15s, transform 0.1s;
flex-shrink: 0;
}
.btn-comprar:hover { opacity: 0.75; transform: translateY(-1px); }

/* SECTIONS */
.section { display: none; }
.section.active { display: block; }

/* FOOTER */
footer {
border-top: 1px solid var(–border);
padding: 24px 32px;
display: flex; align-items: center; justify-content: space-between;
background: var(–bg2);
}
.f-logo { font-family: ‘Cormorant Garamond’, serif; font-size: 1.05rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; }
.f-links { display: flex; gap: 24px; }
.f-links a { font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(–muted); text-decoration: none; transition: color 0.15s; }
.f-links a:hover { color: var(–text); }
.f-note { font-size: 0.6rem; color: var(–muted); }

/* RESPONSIVE */
@media (max-width: 900px) { .grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 600px) {
.topbar { gap: 20px; }
.header-inner { padding: 0 16px; }
.tabs { gap: 2px; padding: 3px; }
.tab { padding: 5px 12px; font-size: 0.65rem; }
.grid { grid-template-columns: repeat(2, 1fr); }
.card-visual { font-size: 2.5rem; }
footer { flex-direction: column; gap: 16px; text-align: center; }
.f-links { justify-content: center; }
.f-note { display: none; }
}
</style>

